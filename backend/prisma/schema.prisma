generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  avatarUrl        String?
  anthropicApiKey  String?
  openaiApiKey     String?
  aiProvider       String   @default("anthropic")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workoutTemplates  WorkoutTemplate[]
  sessions          WorkoutSession[]
  profile           UserProfile?
  programs          Program[]
  plannedWorkouts   PlannedWorkout[]
  weeklyAnalyses    WeeklyAnalysis[]
  bodyLogs          BodyLog[]
  sharedPrograms    SharedProgram[]
  enrollments       ProgramEnrollment[]
  programRatings    ProgramRating[]
}

model BodyLog {
  id        String   @id @default(cuid())
  userId    String
  weight    Float
  unit      String   @default("lbs")
  bodyFat   Float?
  notes     String?
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model UserProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  primaryGoal          String   @default("general_fitness")
  secondaryGoals       String   @default("[]") // JSON array
  experienceLevel      String   @default("intermediate")
  daysPerWeek          Int      @default(3)
  sessionDurationMins  Int      @default(60)
  preferredSplit       String   @default("full_body")
  availableEquipment   String   @default("[]") // JSON array
  restrictions         String   @default("[]") // JSON array
  injuryFlags          String   @default("[]") // JSON array
  workoutEnvironment   String   @default("commercial_gym")
  priorityAreas        String   @default("[]") // JSON array
  programStyle         String   @default("structured")
  benchmarkSquat       Float?
  benchmarkDeadlift    Float?
  benchmarkBench       Float?
  benchmarkPress       Float?
  benchmarkPullups     Int?
  benchmarkMileTime    String?
  bodyweight           Float?
  bodyFatPercent       Float?
  unitSystem           String   @default("lbs")
  onboardingCompleted  Boolean  @default(false)
  aiCoachingSummary    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Program {
  id               String   @id @default(cuid())
  userId           String
  name             String
  description      String?
  totalWeeks       Int      @default(4)
  currentWeek      Int      @default(1)
  status           String   @default("active") // active | completed | archived
  weeklyStructure  String   @default("{}") // JSON
  progressionRules String   @default("{}") // JSON
  aiGoalSummary    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedWorkouts PlannedWorkout[]
  weeklyAnalyses  WeeklyAnalysis[]
  sessions        WorkoutSession[]

  @@index([userId, status])
}

model PlannedWorkout {
  id                String    @id @default(cuid())
  programId         String
  userId            String
  weekNumber        Int
  dayOfWeek         String    // Monday, Tuesday, etc.
  scheduledDate     DateTime?
  name              String
  focus             String?   // e.g. "Upper Push", "Lower Pull"
  warmup            String    @default("[]") // JSON array
  exercises         String    @default("[]") // JSON array — full exercise+sets spec
  conditioning      String?   // JSON object, optional
  coachNotes        String?
  estimatedDuration Int?      // minutes
  isCompleted       Boolean   @default(false)
  completedSessionId String?
  createdAt         DateTime  @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([programId, weekNumber])
  @@index([userId, scheduledDate])
}

model WeeklyAnalysis {
  id                   String   @id @default(cuid())
  programId            String
  userId               String
  weekNumber           Int
  adherenceScore       Float    @default(0)
  fatigueLevel         Int      @default(5)
  progressionNotes     String?
  adjustments          String   @default("[]") // JSON array
  recommendations      String   @default("[]") // JSON array
  weekSummary          String?
  rawAiOutput          String?
  createdAt            DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([programId, weekNumber])
}

model WorkoutTemplate {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  isAiGenerated Boolean  @default(false)
  aiGoal        String?
  programId     String?
  weekNumber    Int?
  dayOfWeek     String?
  source        String   @default("custom") // custom | ai_legacy
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  sessions  WorkoutSession[]

  @@index([userId])
  @@index([userId, programId])
}

model Exercise {
  id         String  @id @default(cuid())
  templateId String
  name       String
  orderIndex Int
  notes      String?

  template    WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sets        ExerciseSet[]
  sessionSets SessionSet[]

  @@index([templateId, orderIndex])
}

model ExerciseSet {
  id            String  @id @default(cuid())
  exerciseId    String
  setNumber     Int
  targetReps    Int?
  targetWeight  Float?
  unit          String  @default("kg")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model WorkoutSession {
  id                 String    @id @default(cuid())
  userId             String
  templateId         String?
  plannedWorkoutId   String?
  programId          String?
  name               String
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  notes              String?
  preEnergyLevel     Int?      // 1-10
  postEnergyLevel    Int?      // 1-10
  sorenessLevel      Int?      // 1-10
  completionScore    Float?
  performanceScore   Float?
  aiSummary          String?   // JSON string of structured AI analysis

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  program  Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  sets     SessionSet[]

  @@index([userId, startedAt])
  @@index([userId, plannedWorkoutId])
}

model SessionSet {
  id           String   @id @default(cuid())
  sessionId    String
  exerciseId   String
  exerciseName String
  setNumber    Int
  actualReps   Int?
  actualWeight Float?
  unit         String   @default("kg")
  rpe          Int?     // Rate of Perceived Exertion 1-10, optional
  completedAt  DateTime @default(now())

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([exerciseId, completedAt])
}

model SharedProgram {
  id              String   @id @default(cuid())
  creatorId       String
  creatorName     String
  creatorAvatar   String?
  name            String
  description     String?
  category        String   @default("general")
  difficulty      String   @default("intermediate")
  durationWeeks   Int      @default(4)
  daysPerWeek     Int      @default(3)
  equipment       String   @default("[]")   // JSON array
  tags            String   @default("[]")   // JSON array
  workoutPlan     String   @default("{}")   // JSON object
  ratingAverage   Float    @default(0)
  enrollmentCount Int      @default(0)
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator      User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  enrollments  ProgramEnrollment[]
  ratings      ProgramRating[]

  @@index([creatorId])
  @@index([category, isPublished])
  @@index([isPublished, createdAt])
}

model ProgramEnrollment {
  id              String   @id @default(cuid())
  userId          String
  sharedProgramId String
  programId       String   // the forked Program id
  enrolledAt      DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedProgram SharedProgram @relation(fields: [sharedProgramId], references: [id], onDelete: Cascade)

  @@unique([userId, sharedProgramId])
  @@index([userId])
}

model ProgramRating {
  id              String   @id @default(cuid())
  userId          String
  sharedProgramId String
  rating          Int
  review          String?
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedProgram SharedProgram @relation(fields: [sharedProgramId], references: [id], onDelete: Cascade)

  @@unique([userId, sharedProgramId])
  @@index([sharedProgramId])
}
